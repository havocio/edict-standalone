# 选择一个 LLM 提供商并填入对应的 API Key
# 支持: openai / anthropic / deepseek / ollama

LLM_PROVIDER=openai        # openai | anthropic | deepseek | ollama
LLM_MODEL=gpt-4o           # 对应提供商的模型名称
LLM_API_KEY=sk-xxxx        # API Key（ollama 不需要）
LLM_BASE_URL=              # 可选，自定义 base URL（如使用中转/Ollama）

# Dashboard 服务端口
DASHBOARD_PORT=7891
DASHBOARD_HOST=127.0.0.1

# 制度选择（可选）
# 可选值: san_sheng_liu_bu（默认）| democratic_centralism
# 也可通过命令行参数 --regime 指定
REGIME=san_sheng_liu_bu
